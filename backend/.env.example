# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/alumni_connect

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Cloudinary (Resume Upload) ───────────────────────────
# Sign up at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer via Gmail SMTP) ────────────────────
# For Gmail: enable "App Passwords" in your Google account security settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="NCPL Alumni Connect <your_email@gmail.com>"

# ── Alternatively: SendGrid ──────────────────────────────
# SENDGRID_API_KEY=your_sendgrid_api_key

# ── Frontend URL (for email action links) ────────────────
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
