# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Supabase Storage ──────────────────────────────────────
# Name of the Storage bucket used for resume PDFs (create it in the dashboard)
SUPABASE_STORAGE_BUCKET=resumes

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer via Gmail SMTP) ────────────────────
# For Gmail: enable "App Passwords" in your Google account security settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="NCPL Alumni Connect <your_email@gmail.com>"

# ── Frontend URL (for email action links) ────────────────
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
