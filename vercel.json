{
  "version": 2,
  "buildCommand": "npm --prefix frontend install && npm --prefix frontend run build && npm --prefix backend install",
  "outputDirectory": "frontend/build",
  "functions": {
    "backend/server.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["bom1"]
}
